@startuml quiz_app_mvvm

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classBackgroundColor #F8F8F8
skinparam classBorderColor #888888
skinparam arrowColor #555555
skinparam linetype ortho

package "UI-Schicht" #EEF0FF {

  class MainActivity {
    - navController: NavController
    --
    + onCreate()
    + onStart()
    + navigateTo(dest: Int)
  }

  class HostActivity {
    - binding: ActivityHostBinding
    --
    + onCreate()
    + onStart()
    + observeViewModel()
  }

  class PlayerActivity {
    - binding: ActivityPlayerBinding
    --
    + onCreate()
    + onStart()
    + observeViewModel()
  }

  class LobbyFragment {
    - binding: FragLobbyBinding
    --
    + onViewCreated()
    + showRoomCode(code: String)
    + onStartClicked()
  }

  class HostQuizFragment {
    - binding: FragHostQuizBinding
    --
    + showQuestion(q: Question)
    + showAnswerStats()
    + onNextClicked()
  }

  class PlayerQuizFragment {
    - binding: FragPlayerQuizBinding
    --
    + showQuestion(q: Question)
    + showAnswerChoices()
    + onAnswerSelected(answerId: String)
  }

  class ResultFragment {
    - binding: FragResultBinding
    --
    + showLeaderboard(lb: Leaderboard)
    + highlightWinner(entry: LeaderboardEntry)
  }

}

package "ViewModel-Schicht" #FFF0EE {

  class HostViewModel {
    - hostService: GameHostService
    --
    + sessionState: LiveData<GameState>
    + currentQuestion: LiveData<Question>
    + playerAnswers: LiveData<List<PlayerAnswer>>
    + leaderboard: LiveData<Leaderboard>
    --
    + createSession(quiz: Quiz)
    + startSession()
    + advanceToNextQuestion()
    + endGame()
  }

  class PlayerViewModel {
    - playerService: GamePlayerService
    --
    + currentQuestion: LiveData<Question>
    + leaderboard: LiveData<Leaderboard>
    --
    + joinSession(url: String, username: String)
    + pollForQuestion()
    + submitAnswer(questionId: String, answerId: String)
    + loadLeaderboard()
  }

}

package "Domain-Schicht (Referenz)" #F0F0F0 {
  class GameSession
  class Quiz
  class Question
  class PlayerAnswer
  class Leaderboard
  class LeaderboardEntry
  enum GameState
  interface IHostNetwork
  interface IPlayerNetwork
}

package "Netzwerk-Schicht (Referenz)" #EAF3DE {
  class GameHostService
  class GamePlayerService
  class NetworkDiscovery
  class GameStateDto
}

' Realisierung: Networking implementiert Interfaces
GameHostService ..|> IHostNetwork
GamePlayerService ..|> IPlayerNetwork

' Activity hostet Fragments
HostActivity ..> LobbyFragment : hosts
HostActivity ..> HostQuizFragment : hosts
HostActivity ..> ResultFragment : hosts
PlayerActivity ..> PlayerQuizFragment : hosts
PlayerActivity ..> ResultFragment : hosts

' Fragments beobachten ViewModels
LobbyFragment --> HostViewModel : observes
HostQuizFragment --> HostViewModel : observes
ResultFragment --> HostViewModel : observes
PlayerQuizFragment --> PlayerViewModel : observes
ResultFragment --> PlayerViewModel : observes

' ViewModels -> Networking-Services
HostViewModel --> GameHostService : uses
PlayerViewModel --> GamePlayerService : uses

' ViewModels -> Domain
HostViewModel ..> GameSession : uses
HostViewModel ..> Quiz : uses
HostViewModel ..> Question : uses
HostViewModel ..> PlayerAnswer : uses
HostViewModel ..> Leaderboard : uses
PlayerViewModel ..> Question : uses
PlayerViewModel ..> Leaderboard : uses

@enduml
